                    <mxGeometry x="150" y="455" width="250" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="table_content" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Courier New&quot; size=&quot;2&quot;&gt;&lt;b&gt;Cycle 0 (Initial):&lt;/b&gt;&lt;br&gt;  train:  [0, 1216)    = 2016-01-04 ~ 2020-12-31  (&lt;b&gt;1216 days&lt;/b&gt;)&lt;br&gt;  val:    [1216, 1944) = 2021-01-04 ~ 2023-12-29  (728 days)&lt;br&gt;  test:   [1944, 1965) = 2024-01-02 ~ 2024-01-30  (21 days)&lt;br&gt;&lt;br&gt;&lt;b&gt;Cycle 1 (Fine-tune):&lt;/b&gt;&lt;br&gt;  train:  [0, 1237)    = 2016-01-04 ~ 2021-02-01  (&lt;b&gt;1237 days&lt;/b&gt;)&lt;br&gt;  val:    [1237, 1965) = 2021-02-02 ~ 2024-01-30  (728 days)&lt;br&gt;  test:   [1965, 1986) = 2024-01-31 ~ 2024-03-11  (21 days)&lt;br&gt;&lt;br&gt;&lt;b&gt;Cycle N:&lt;/b&gt;&lt;br&gt;  train_idx = 0 (always), train_idx_end += 21 * N&lt;/font&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacing=5;" parent="1" vertex="1">
