                </mxCell>
                <mxCell id="diff_title" value="&lt;b&gt;Key Differences from Sliding&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="450" y="325" width="200" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="diff_content" value="&lt;div style=&quot;text-align: left;&quot;&gt;1. &lt;b&gt;test_idx_end = 2429&lt;/b&gt;&lt;br&gt;   Tests on ALL remaining data&lt;br&gt;   (not just 21 days)&lt;br&gt;&lt;br&gt;2. &lt;b&gt;epochs = 1500&lt;/b&gt;&lt;br&gt;   Much longer training&lt;br&gt;   (vs 50 initial + 10 finetune)&lt;br&gt;&lt;br&gt;3. &lt;b&gt;Single training run&lt;/b&gt;&lt;br&gt;   No rolling/sliding window&lt;br&gt;   No model fine-tuning cycles&lt;br&gt;&lt;br&gt;4. &lt;b&gt;Uses run.py, not run_2.py&lt;/b&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="450" y="350" width="260" height="185" as="geometry"/>
                </mxCell>
                <mxCell id="pros_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="740" y="320" width="240" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pros_title" value="&lt;b&gt;Pros &amp;amp; Cons&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="750" y="325" width="150" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="pros_content" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Pros:&lt;/b&gt;&lt;br&gt;- Simpler, one training run&lt;br&gt;- Tests entire future period&lt;br&gt;- Good for backtesting&lt;br&gt;&lt;br&gt;&lt;b&gt;Cons:&lt;/b&gt;&lt;br&gt;- No adaptation to new data&lt;br&gt;- Model may become stale&lt;br&gt;- Tests on unseen market&lt;br&gt;  regime without updates&lt;br&gt;- Unrealistic for production&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="750" y="350" width="220" height="185" as="geometry"/>
                </mxCell>
                <mxCell id="script_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="320" width="200" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="script_title" value="&lt;b&gt;Usage&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1010" y="325" width="150" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="script_content" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font face=&quot;Courier New&quot;&gt;# Standard training&lt;br&gt;python run.py \\&lt;br&gt;  -c hyper.json&lt;br&gt;&lt;br&gt;# Test only&lt;br&gt;python test.py \\&lt;br&gt;  -c hyper.json \\&lt;br&gt;  --model_path ...&lt;/font&gt;&lt;br&gt;&lt;br&gt;Output saved to:&lt;br&gt;&lt;font face=&quot;Courier New&quot;&gt;./src/outputs/&lt;br&gt;  MMDD/HHMMSS/&lt;/font&gt;&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1010" y="350" width="180" height="185" as="geometry"/>
                </mxCell>
                <mxCell id="comparison_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="140" y="560" width="1060" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="comparison_title" value="&lt;b&gt;Comparison: Standard vs Sliding Window Approaches&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="140" y="565" width="1060" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="comparison_table" value="&lt;table style=&quot;border-collapse: collapse; width: 100%; font-size: 11px;&quot;&gt;&lt;tr style=&quot;background-color: #e0e0e0;&quot;&gt;&lt;th style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Aspect&lt;/th&gt;&lt;th style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Standard (hyper.json)&lt;/th&gt;&lt;th style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Sliding Fixed (hyper_sliding.json)&lt;/th&gt;&lt;th style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Sliding Expanding&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;&lt;b&gt;Script&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;run.py&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;run_2.py&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;run_2.py&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;&lt;b&gt;Epochs&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;1500 (single run)&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;50 + 10 x N cycles&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;50 + 10 x N cycles&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;&lt;b&gt;Test Period&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;485 days (all future)&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;21 days per cycle&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;21 days per cycle&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;&lt;b&gt;Train Size&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Fixed (1216)&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Fixed (1216)&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Growing (1216+)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;&lt;b&gt;Adaptation&lt;/b&gt;&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;None&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Fine-tune per cycle&lt;/td&gt;&lt;td style=&quot;border: 1px solid #999; padding: 5px;&quot;&gt;Fine-tune per cycle&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;" parent="1" vertex="1">
